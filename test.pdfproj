            "AINote|4c874914-b355-447e-905b-37b26bc7de8f": {
                "quote": "Aesthetics of wartime computing prized discipline, order, and exactness - traits associated with feminine service roles.",
                "note": "This quote demonstrates how aesthetics in technology and labor during wartime were influenced by gendered expectations. The association of disciplined, orderly work (traditionally linked to femininity) with computing reinforces societal norms that contributed to the marginalization and objectification of women's contributions in tech fields.",
                "color": "#2d2238",
                "is_custom": false,
                "pdf_path": "/home/sunbear/Downloads/Light When Computers Were Women.pdf",
